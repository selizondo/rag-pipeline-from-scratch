# No API keys required — pipeline runs fully locally via Ollama.
# Prerequisites: Ollama installed and running (https://ollama.com).

# Optional: Kaggle credentials for full corpus.
# Without these, seed_corpus.py --skip-kaggle pulls HuggingFace sources only.
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# Optional: override default Ollama model (default: llama3.2)
# OLLAMA_MODEL=llama3.2
